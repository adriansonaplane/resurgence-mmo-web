  "phase_count": 20,
  "required_stack": {
    "frontend": "Angular + Angular SSR + TypeScript",
    "backend": "Node.js + NestJS + Fastify Adapter + TypeScript",
    "database": "Neon PostgreSQL",
    "orm": "Drizzle ORM",
    "cms": "Directus",
    "auth": "Auth0 + OAuth 2.0 + OpenID Connect",
    "payments": "Stripe Checkout + Stripe Webhooks",
    "hosting": "Google Cloud Run",
    "ci_cd": "GitHub Actions",
    "frontend_testing": [
      "Angular Testing Utilities",
      "Playwright",
      "Jest"
    ],
    "backend_testing": [
      "Jest",
      "Fastify Inject",
      "Testcontainers"
    ],
    "excluded": [
      "Supertest",
      "Plain Express backend",
      "Direct game-critical table writes from web platform",
      "Web login treated as game session",
      "Directus authoritative gameplay config"
    ],
    "boundary": "Companion Web Platform supports game but does not simulate game; Account Service boundary required for cross-boundary account/session operations; website DB separate from game DB"
  },
