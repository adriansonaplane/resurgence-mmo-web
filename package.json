{
  "name": "mmo-website-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/frontend"
  ],
  "scripts": {
    "lint": "npm run lint -w apps/api && npm run lint -w apps/frontend",
    "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test -w apps/api",
    "test:frontend": "npm run test -w apps/frontend",
    "test:integration": "npm run test:integration -w apps/api",
    "test:e2e:smoke": "npm run test:e2e:smoke -w apps/frontend",
    "test:acceptance": "node scripts/acceptance-gates.mjs",
    "build": "npm run build -w apps/api && npm run build -w apps/frontend",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:frontend": "npm run start -w apps/frontend",
    "db:generate": "npm run db:generate -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api"
  },
  "engines": {
    "node": ">=22"
  }
}
